[Unit]
Description=Chatbot - ngrok Tunnels
After=network-online.target chatbot.service
Wants=network-online.target
Requires=chatbot.service

[Service]
Type=simple
ExecStart=/usr/local/bin/ngrok start --all
User=jadaboawwad
Group=jadaboawwad
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
