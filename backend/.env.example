# Backend environment (copy to backend/.env for local dev)
DATABASE_URL=postgresql+asyncpg://rag:rag_secret@localhost:5432/ragdb
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
EMBEDDING_MODEL=intfloat/multilingual-e5-large
LLM_TEMPERATURE=0.9
LLM_NUM_PREDICT=512
ARABIC_POLISH_ENABLED=false
MAX_CONTEXT_CHUNKS=3
CONTEXT_CHUNK_MAX_CHARS=400
VECTOR_STORE_PATH=./data/vector_store
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TURBOVEC_BIT_WIDTH=4
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
HYBRID_SEARCH_ENABLED=true
# Enable only when latency budget allows (adds an extra LLM call per question).
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_TIMEOUT_SECONDS=10
MULTI_QUERY_COUNT=3
TOP_K=5
RETRIEVAL_MIN_K=6
RETRIEVAL_FETCH_MULTIPLIER=2
RRF_K=60
RERANKER_MIN_SCORE=-0.5
CONTEXT_SCORE_MARGIN=1.5
PORTFOLIO_LLM_NUM_PREDICT=384
PORTFOLIO_MAX_CONTEXT_CHUNKS=4
PORTFOLIO_CONTEXT_CHUNK_MAX_CHARS=1800
PORTFOLIO_TOP_K=5
PORTFOLIO_RERANKER_ENABLED=true
TORCH_DEVICE=cuda
